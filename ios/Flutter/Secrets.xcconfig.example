// ios/Flutter/Secrets.xcconfig — copy to Secrets.xcconfig (gitignored) and fill in real values.
// Never commit Secrets.xcconfig; inject secrets via CI environment variables instead.
//
// Required for Airbridge SDK initialization and iOS entitlements generation:
//
//   AIRBRIDGE_APP_NAME   — your Airbridge app name (e.g. webuddhist for prod, webuddhistdev for dev)
//   AIRBRIDGE_SDK_TOKEN  — your Airbridge SDK token from the Airbridge dashboard
//
// In CI (Codemagic / Xcode Cloud), set these as environment variables and let the
// Generate Entitlements build phase read them directly (no Secrets.xcconfig needed).

AIRBRIDGE_APP_NAME=your-airbridge-app-name
AIRBRIDGE_SDK_TOKEN=your-airbridge-sdk-token
