# android/local.properties — copy to local.properties (gitignored) and fill in real values.
# Never commit local.properties; inject secrets via CI environment variables instead.
#
# Flutter SDK path (required by the build system — set automatically by Android Studio / flutter run)
flutter.sdk=/path/to/flutter/sdk
#
# Airbridge credentials (used by build.gradle.kts to populate BuildConfig fields)
#   In CI (Codemagic etc.) set AIRBRIDGE_APP_NAME and AIRBRIDGE_SDK_TOKEN as environment variables;
#   the Gradle script reads env vars first and falls back to these properties.
#
#   AIRBRIDGE_APP_NAME: your Airbridge app name — use "webuddhistdev" for dev flavor,
#                       "webuddhist" for staging and prod flavors.
#   AIRBRIDGE_SDK_TOKEN: SDK token from the Airbridge dashboard (Settings > SDK Token).
airbridge.app.name=your-airbridge-app-name
airbridge.app.token=your-airbridge-sdk-token
