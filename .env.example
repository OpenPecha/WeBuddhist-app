# API
BASE_API_URL=https://api.example.com
AI_URL=https://aichat.example.com
ENVIRONMENT=development

# Auth0 (optional — can also be fetched from /props)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
AUTH0_SCHEME=

# PostHog (one project per flavor — use different tokens in .env.dev / .env.staging / .env.prod)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ENABLED=true
