# Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# Base API URL
BASE_API_URL=//api.example.com

# =============================================================================
# Analytics (PostHog)
# =============================================================================
# Leave POSTHOG_API_KEY empty to disable analytics — the app falls back to a
# no-op service. Use a separate PostHog project per flavor (dev / staging /
# prod) so debug traffic never pollutes production dashboards.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com


